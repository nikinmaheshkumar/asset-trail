generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  MASTER_ADMIN
  BOARD
  SENIOR_CORE
  JUNIOR_CORE
}

enum ItemStatus {
  WORKING
  NEEDS_TESTING
  FAULTY
  SCRAP
}

enum LoanStatus {
  REQUESTED
  APPROVED
  CLOSED
  REJECTED
}

model Member {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(JUNIOR_CORE)
  mustChangePwd Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  loans           Loan[]   @relation("MemberLoans")
  approved_loans  Loan[]   @relation("LoanApprover")
}

model Item {
  id                 Int        @id @default(autoincrement())
  name               String
  category           String
  quantity_total     Int
  quantity_available Int
  location           String
  status             ItemStatus @default(WORKING)
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt

  loans              Loan[]
}

model Loan {
  id           Int        @id @default(autoincrement())
  item_id      Int
  member_id    Int
  requested_at DateTime   @default(now())
  approved_at  DateTime?
  closed_at    DateTime?
  due_date     DateTime?
  purpose      String
  status       LoanStatus @default(REQUESTED)
  approved_by  Int?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  item     Item    @relation(fields: [item_id], references: [id])
  member   Member  @relation("MemberLoans", fields: [member_id], references: [id])
  approver Member? @relation("LoanApprover", fields: [approved_by], references: [id])

  @@index([item_id])
  @@index([member_id])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  action     String
  actor_id   Int
  target_id  Int?
  created_at DateTime @default(now())
}